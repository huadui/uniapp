
.history-container.data-v-b2d018fa {
  min-height: 100vh;
  padding-bottom: 90px;
  background-color: #F7F5F0;
  background-image: radial-gradient(#E8E6E1 1px, transparent 1px);
  background-size: 20px 20px;
  color: #4A4A4A;
  font-family: "PingFang SC", "Kaiti SC", serif;
}

/* 顶部导航 */
.navbar.data-v-b2d018fa {
  background: rgba(247, 245, 240, 0.95);
  padding: 12px 20px;
  padding-top: calc(44px + env(safe-area-inset-top));
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1px solid #E8E0D5;
  position: -webkit-sticky;
  position: sticky;
  top: 0;
  z-index: 100;
}
.nav-title.data-v-b2d018fa { font-size: 18px; font-weight: 600; color: #333; font-family: "Kaiti SC", "STKaiti", serif;
}
.clear-btn.data-v-b2d018fa { position: absolute; right: 20px; color: #888; font-size: 14px;
}
.list-container.data-v-b2d018fa { padding: 20px;
}

/* 时间轴样式 */
.timeline-block.data-v-b2d018fa { position: relative; padding-left: 24px; margin-bottom: 24px;
}
.timeline-block.data-v-b2d018fa::before {
  content: '';
  position: absolute;
  left: 6px; top: 28px; bottom: -20px;
  width: 1px; background: #D8D0C5;
  border-left: 1px dashed #D8D0C5;
}
.timeline-block.data-v-b2d018fa:last-child::before { display: none;
}
.date-label.data-v-b2d018fa {
  font-size: 14px;
  font-weight: bold;
  color: #8B5A2B;
  margin-bottom: 12px;
  position: relative;
}
.date-label.data-v-b2d018fa::before {
  content: '';
  position: absolute;
  left: -28px; top: 4px;
  width: 12px; height: 12px;
  background: #8B5A2B;
  border: 3px solid #F7F5F0;
  border-radius: 50%;
  box-shadow: 0 0 0 1px #8B5A2B;
}
.record-card.data-v-b2d018fa {
  background: #fff;
  border-radius: 8px;
  padding: 16px;
  margin-bottom: 12px;
  display: flex;
  gap: 16px;
  align-items: flex-start;
  box-shadow: 0 2px 8px rgba(139, 90, 43, 0.08);
  border: 1px solid #E8E0D5;
  position: relative;
}
.record-card.data-v-b2d018fa::after {
  content: '';
  position: absolute;
  top: 4px; bottom: 4px; left: 4px;
  width: 2px;
  background-image: linear-gradient(to bottom, #8B5A2B 33%, transparent 0%);
  background-size: 1px 6px;
  opacity: 0.3;
}
.record-icon-box.data-v-b2d018fa {
  width: 40px; height: 40px;
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  font-size: 20px;
  flex-shrink: 0;
}
.bg-ink.data-v-b2d018fa { background: #F0EBE5; color: #4A4A4A;
}
.bg-red.data-v-b2d018fa { background: #FBE8E6; color: #C84C42;
}
.record-content.data-v-b2d018fa { flex: 1;
}
.record-title.data-v-b2d018fa { font-size: 16px; font-weight: 600; color: #333; margin-bottom: 4px; font-family: "Kaiti SC", "STKaiti", serif;
}
.record-desc.data-v-b2d018fa { font-size: 13px; color: #666; line-height: 1.5; margin-bottom: 10px;
}
.tags.data-v-b2d018fa { display: flex; gap: 6px;
}
.tag.data-v-b2d018fa { 
  font-size: 10px; 
  padding: 2px 6px; 
  border-radius: 4px; 
  background: #F7F5F0; 
  color: #8B5A2B; 
  border: 1px solid #E0D8CE;
}
.time.data-v-b2d018fa { font-size: 12px; color: #bbb; margin-top: 8px; text-align: right; font-family: "Georgia", serif; font-style: italic;
}

/* 底部 Tab */
.tabbar.data-v-b2d018fa {
  position: fixed;
  bottom: 20px;
  left: 20px; right: 20px;
  height: 60px;
  background: #fff;
  border-radius: 30px;
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 8px 30px rgba(0,0,0,0.1);
  border: 1px solid rgba(0,0,0,0.05);
  z-index: 100;
}
.tab-item.data-v-b2d018fa {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  color: #999;
  flex: 1; height: 100%;
}
.tab-item.active.data-v-b2d018fa { color: #8B5A2B;
}
.tab-icon.data-v-b2d018fa { font-size: 24px; margin-bottom: 2px;
}
.tab-text.data-v-b2d018fa { font-size: 10px; font-weight: 500;
}
