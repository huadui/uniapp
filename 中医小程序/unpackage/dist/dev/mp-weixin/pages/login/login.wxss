  cursor: pointer;
}
.checkbox.checked.data-v-e4e4508d { background: #8B5A2B; border-color: #8B5A2B;
}
.checkbox.checked.data-v-e4e4508d::after { content: '✓'; font-size: 10px;
}
.link.data-v-e4e4508d { color: #8B5A2B; text-decoration: none; border-bottom: 1px dashed #8B5A2B;
}

/* 底部版权 */
.footer.data-v-e4e4508d {
  position: absolute;
  bottom: 30px;
  font-size: 10px;
