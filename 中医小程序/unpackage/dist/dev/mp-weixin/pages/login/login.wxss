  font-family: "PingFang SC", sans-serif;
}
.login-btn.data-v-e4e4508d:active { transform: scale(0.98);
}
.agreement-box.data-v-e4e4508d {
  margin-top: 24px;
  font-size: 12px;
  color: #999;
  display: flex;
  align-items: center;
  justify-content: center;
